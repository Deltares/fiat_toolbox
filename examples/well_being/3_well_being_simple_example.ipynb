    "#  Run the well-being model for each household type and optimize lambda\n",
    "losses = {}\n",
    "objects = {}\n",
    "\n",
    "for i, household in df.iterrows():\n",
    "    name = household[\"Household Type\"]\n",
    "    config = WellBeingConfig(\n",
    "        housing=CapitalStock(k=household[\"Asset Value\"], v=household[\"Relative Damage\"]),\n",
    "        income=IncomeConfig(i_0=household[\"Yearly Income\"], i_avg=inc_avg, pi=0.15, c_i_ratio=1.0),\n",
    "        liquidity=Liquidity(),\n",
    "        simulation=SimulationConfig(\n",
    "            eta=1.5, rho=0.06, t_max=10, dt=1 / 365, currency=currency, c_min=household[\"cmin\"]\n",
    "        ),\n",
    "    )\n",
    "    var = CommunityUnit(config)\n",
    "    var.opt_lambda(eps_rel=household[\"eps_rel\"])\n",
    "    losses[name] = var.get_losses()\n",
    "    objects[name] = var\n",
    "\n",
    "\n",
    "losses = pd.DataFrame(losses)\n",
    "losses"
   ]
